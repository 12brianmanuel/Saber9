                            opt.classList.remove('hover:bg-slate-50', 'border-gray-300');
                            
                            // Resaltar la respuesta correcta sin importar lo que el usuario eligió
                            if (opt.getAttribute('data-correct') === 'true') {
                                opt.classList.remove('disabled'); // Mantener visiblemente fuerte la correcta
                                opt.classList.add('border-emerald-500', 'bg-emerald-50');
                                const letterSpan = opt.querySelector('span:first-child');
                                letterSpan.classList.replace('bg-blue-50', 'bg-emerald-200');
                                letterSpan.classList.replace('text-blue-900', 'text-emerald-900');
                                letterSpan.classList.remove('group-hover:bg-blue-100');
                            }
                        });

                        // 2. Si el usuario se equivocó, resaltar su elección en rojo
                        if (!isCorrect) {
                            this.classList.remove('disabled'); // Mantener visiblemente fuerte el error
                            this.classList.add('border-rose-500', 'bg-rose-50', 'shadow-sm');
                            const letterSpan = this.querySelector('span:first-child');
                            letterSpan.classList.replace('bg-blue-50', 'bg-rose-200');
                            letterSpan.classList.replace('text-blue-900', 'text-rose-900');
                            letterSpan.classList.remove('group-hover:bg-blue-100');
                        } else {
                            this.classList.add('shadow-md');
                        }

                        // 3. Mostrar la Caja de Retroalimentación Pedagógica
                        feedbackEl.classList.remove('hidden');
                        feedbackEl.style.animation = 'fadeIn 0.5s cubic-bezier(0.4, 0, 0.2, 1)';

                        if (isCorrect) {
                            feedbackEl.innerHTML = `
                                <h4 class="font-extrabold mb-3 text-emerald-800 flex items-center gap-3 text-lg">
                                    <span class="text-2xl bg-emerald-100 rounded-full w-8 h-8 flex items-center justify-center pb-0.5">&#10004;</span> 
                                    Lógica Acertada:
                                </h4>
                                <p class="text-emerald-900 leading-relaxed">${feedbackText}</p>
                            `;
                            feedbackEl.className = 'quiz-feedback mt-6 p-6 rounded-xl border-2 bg-emerald-50 border-emerald-400 shadow-inner';
                        } else {
                            feedbackEl.innerHTML = `
                                <h4 class="font-extrabold mb-3 text-rose-800 flex items-center gap-3 text-lg">
                                    <span class="text-xl bg-rose-200 text-rose-800 rounded-full w-8 h-8 flex items-center justify-center font-bold">X</span> 
                                    Fallo Conceptual:
                                </h4>
                                <p class="text-rose-900 leading-relaxed">${feedbackText}</p>
                            `;
                            feedbackEl.className = 'quiz-feedback mt-6 p-6 rounded-xl border-2 bg-rose-50 border-rose-300 shadow-inner';
                        }
                    });
                });
            });
        }
    </script>
</body>
</html>
