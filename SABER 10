        // Controlador de Navegación de Pestañas
        function initNavigation() {
            const tabs = document.querySelectorAll('.tab-btn');
            const contents = document.querySelectorAll('.section-content');

            tabs.forEach(tab => {
                tab.addEventListener('click', () => {
                    // Desactivar todos los elementos
                    tabs.forEach(t => {
                        t.classList.remove('active', 'text-blue-800');
                        t.classList.add('text-gray-500');
                    });
                    contents.forEach(c => c.classList.remove('active'));

                    // Activar el elemento clickeado
                    tab.classList.add('active', 'text-blue-800');
                    tab.classList.remove('text-gray-500');
                    
                    const targetId = tab.getAttribute('data-target');
                    document.getElementById(targetId).classList.add('active');

                    // Inicializar el gráfico SÓLO si se entra a la vista de Dashboard
                    if (targetId === 'dashboard') {
                        initCharts();
                    }
                });
            });
        }

